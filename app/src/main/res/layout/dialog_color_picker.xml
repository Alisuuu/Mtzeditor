<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Seletor Principal -->
        <com.crosspro.noactivity.TriangleColorPickerView
            android:id="@+id/triangle_picker"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginBottom="16dp" />

        <!-- Preview de Contraste e Hex -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:background="#1E1E1E"
            android:padding="4dp"
            android:layout_marginBottom="16dp">
            
            <FrameLayout
                android:id="@+id/contrast_preview"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#FF0000">
                <TextView
                    android:id="@+id/text_preview_black"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABC"
                    android:textColor="#000000"
                    android:layout_gravity="center_vertical|left"
                    android:layout_marginStart="16dp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/text_preview_white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABC"
                    android:textColor="#FFFFFF"
                    android:layout_gravity="center_vertical|right"
                    android:layout_marginEnd="16dp"
                    android:textStyle="bold" />
            </FrameLayout>

            <EditText
                android:id="@+id/edit_hex_value"
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="#00FFFF"
                android:fontFamily="monospace"
                android:background="@null"
                android:textSize="14sp"
                android:hint="#HEX" />
        </LinearLayout>

        <!-- Opacidade -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Opacidade (Alpha)"
            android:textColor="#888888"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:layout_marginBottom="4dp"/>
        <SeekBar
            android:id="@+id/seekbar_alpha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="255"
            android:layout_marginBottom="24dp" />

        <!-- Cores Recentes -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Usadas recentemente"
            android:textColor="#888888"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"/>
        <LinearLayout
            android:id="@+id/recent_colors_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp" />

        <!-- Paleta Rápida -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paleta Padrão"
            android:textColor="#888888"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"/>
        <GridLayout
            android:id="@+id/preset_colors_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="6"
            android:alignmentMode="alignMargins" />

    </LinearLayout>
</ScrollView>
